#
# SDK/Examples/smakefile - build ZTest (z.library smoke harness)
#
# Prerequisite: smake install + smake headers in Source/lib_source
#

CC      = sc
LD      = slink
RM      = delete force quiet

TARGET  = ZTest

all: $(TARGET)

rebuild: clean all

$(TARGET): ZTest.o libbases.o smakefile.wth
	$(LD) WITH smakefile.wth

ZTest.o: ZTest.c
	$(CC) ZTest.c OBJNAME=ZTest.o

libbases.o: libbases.c
	$(CC) libbases.c OBJNAME=libbases.o

clean:
	-$(RM) ZTest.o
	-$(RM) libbases.o
	-$(RM) $(TARGET)
	-$(RM) $(TARGET).info
